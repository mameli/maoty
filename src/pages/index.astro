---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import profilePic from '../assets/profile.png';
import albums from '../data/album-list.json';

type Album = {
  artist: string;
  album: string;
  genre_tags: string[];
  score: number;
  score_type: string;
  apple_music: string;
  aoty_url: string;
  source: 'must-hear' | 'new-releases';
  review_count: number | null;
  taste_label: "It's a match" | 'Just for you' | "Maybe you'll like it" | null;
  source_rank: number;
  batch_date?: string | null;
};

const albumList = (albums as Album[])
  .map((album, index) => ({ album, index }))
  .sort((left, right) => {
    const leftTime = left.album.batch_date ? Date.parse(left.album.batch_date) : Number.NEGATIVE_INFINITY;
    const rightTime = right.album.batch_date ? Date.parse(right.album.batch_date) : Number.NEGATIVE_INFINITY;

    if (leftTime !== rightTime) {
      return rightTime - leftTime;
    }

    return left.index - right.index;
  })
  .map(({ album }) => album);
const sourceLabel: Record<Album['source'], string> = {
  'must-hear': 'Must Hear',
  'new-releases': 'New Releases',
};
---

<Layout title="Maoty">
  <main class="min-h-screen bg-amber-50 px-6 py-10 text-gray-800">
    <section class="mx-auto flex w-full max-w-5xl flex-col gap-8">
      <div class="flex flex-col items-center gap-5 text-center">
        <h1 class="text-6xl font-bold tracking-[0.06em] sm:text-7xl">Maoty</h1>

        <div class="w-36 rounded-full bg-gradient-to-br from-green-900/10 via-white/85 to-green-700/10 p-2 shadow-[0_22px_45px_-28px_rgba(20,83,45,0.95)] sm:w-44">
          <Image
            src={profilePic}
            alt="Maoty profile picture"
            width={260}
            height={260}
            format="webp"
            class="block aspect-square w-full rounded-full object-cover"
          />
        </div>

        <div class="max-w-2xl">
          <p class="mx-auto mb-3 text-xl leading-relaxed text-gray-700 sm:text-2xl">
            This is an auto-updated website that gathers new albums from the internet
            and highlights the ones I want to keep an eye on.
          </p>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {albumList.map((album) => (
          <article class="self-start rounded-[1.4rem] border border-green-900/10 bg-white/75 p-5">
            <div class="mb-3 flex items-start justify-between gap-3 border-b border-green-900/10 pb-3">
              <div>
                <p class="text-xs uppercase tracking-[0.22em] text-green-800/70">
                  {sourceLabel[album.source]}
                </p>
                <h2 class="mt-1 min-h-[4.4rem] text-3xl leading-none text-gray-900">
                  <a href={album.aoty_url} target="_blank" rel="noreferrer" class="hover:text-green-900">
                    {album.album}
                  </a>
                </h2>
                <p class="mt-2 text-lg text-gray-700">{album.artist}</p>
              </div>
              <div class="pt-1 text-right text-gray-600">
                <p class="text-2xl leading-none text-gray-900">{album.score}</p>
                <p class="mt-1 text-[0.7rem] uppercase tracking-[0.18em] text-gray-500">
                  {album.score_type.replace(' score', '')}
                </p>
              </div>
            </div>

            <div class="mb-4 flex flex-wrap gap-2">
              {album.genre_tags.map((tag) => (
                <span class="text-sm tracking-[0.08em] text-green-900/80">
                  {tag}
                </span>
              ))}
            </div>

            <div class="flex items-center justify-between border-t border-green-900/10 pt-4">
              <p class="text-sm tracking-[0.08em] text-green-900/70">
                {album.taste_label}
              </p>
              <a
                href={album.apple_music}
                target="_blank"
                rel="noreferrer"
                class="text-sm uppercase tracking-[0.18em] text-green-800 transition hover:text-green-950"
              >
                Apple Music
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
